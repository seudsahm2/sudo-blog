# Core security/runtime
SECRET_KEY=replace-with-a-long-random-value
DEBUG=False
FORCE_HTTPS=True
ALLOWED_HOSTS=your-service.onrender.com,yourdomain.com,www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://your-service.onrender.com,https://yourdomain.com,https://www.yourdomain.com

# Database (Render PostgreSQL)
USE_POSTGRES=True
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DB_SSLMODE=require
DB_CONN_MAX_AGE=120

# Static and cache
REDIS_URL=

# No-worker mode (free-tier friendly): run pipeline manually from /blog/analytics/
CELERY_TASK_ALWAYS_EAGER=True

# Email
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Sudo Blog <no-reply@yourdomain.com>

# API keys
NEWSAPI_KEY=
NEWSAPI_COUNTRY=us
NEWSAPI_QUERY=
GNEWS_COUNTRY=us
GNEWS_TOPIC=
GNEWS_QUERY=
GNEWS_KEY=
MEDIASTACK_KEY=
NEWSDATA_COUNTRY=us
NEWSDATA_QUERY=
NEWSDATA_KEY=
GUARDIAN_KEY=
AI_SUMMARY_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_API_KEYS=
GROQ_API_KEY=

# AdSense
ADSENSE_ENABLED=True
ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx
ADSENSE_SLOT_HEADER=
ADSENSE_SLOT_IN_FEED=
ADSENSE_SLOT_IN_ARTICLE=
ADSENSE_SLOT_FOOTER=
ADSENSE_SLOT_TRENDING=
ADSENSE_SLOT_BELOW_CONTENT=
ADSENSE_SLOT_STICKY_MOBILE=
